{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HelmValues",
  "description": "Helm values structure that maps to values.yaml",
  "type": "object",
  "properties": {
    "affinity": {
      "description": "Affinity rules",
      "default": null
    },
    "cluster": {
      "description": "Cluster mode configuration",
      "$ref": "#/$defs/ClusterConfig"
    },
    "frogdb": {
      "description": "FrogDB configuration",
      "$ref": "#/$defs/FrogdbConfig"
    },
    "grafana": {
      "description": "Grafana dashboard provisioning",
      "$ref": "#/$defs/GrafanaConfig"
    },
    "image": {
      "description": "Container image configuration",
      "$ref": "#/$defs/ImageConfig"
    },
    "nodeSelector": {
      "description": "Node selector",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "persistence": {
      "description": "Persistence volume configuration",
      "$ref": "#/$defs/PersistenceVolumeConfig"
    },
    "podDisruptionBudget": {
      "description": "Pod disruption budget",
      "$ref": "#/$defs/PdbConfig"
    },
    "replicaCount": {
      "description": "Number of replicas (1 for standalone, 3+ for cluster)",
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "resources": {
      "description": "Resource limits and requests",
      "$ref": "#/$defs/ResourceConfig"
    },
    "service": {
      "description": "Kubernetes service configuration",
      "$ref": "#/$defs/ServiceConfig"
    },
    "serviceMonitor": {
      "description": "ServiceMonitor for Prometheus Operator",
      "$ref": "#/$defs/ServiceMonitorConfig"
    },
    "tolerations": {
      "description": "Tolerations",
      "type": "array",
      "default": [],
      "items": true
    }
  },
  "required": [
    "replicaCount",
    "image",
    "frogdb",
    "cluster",
    "service",
    "resources",
    "persistence",
    "podDisruptionBudget",
    "serviceMonitor",
    "grafana"
  ],
  "$defs": {
    "AdminConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        }
      },
      "required": [
        "enabled",
        "port"
      ]
    },
    "ClusterConfig": {
      "type": "object",
      "properties": {
        "autoFailover": {
          "type": "boolean"
        },
        "busPort": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "dataDir": {
          "type": "string"
        },
        "electionTimeoutMs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "enabled": {
          "type": "boolean"
        },
        "heartbeatIntervalMs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "enabled",
        "busPort",
        "dataDir",
        "electionTimeoutMs",
        "heartbeatIntervalMs",
        "autoFailover"
      ]
    },
    "FrogdbConfig": {
      "type": "object",
      "properties": {
        "admin": {
          "$ref": "#/$defs/AdminConfig"
        },
        "allowCrossSlotStandalone": {
          "type": "boolean"
        },
        "logging": {
          "$ref": "#/$defs/LoggingConfig"
        },
        "memory": {
          "$ref": "#/$defs/MemoryConfig"
        },
        "metrics": {
          "$ref": "#/$defs/MetricsConfig"
        },
        "numShards": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "persistence": {
          "$ref": "#/$defs/PersistenceConfig"
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "scatterGatherTimeoutMs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "security": {
          "$ref": "#/$defs/SecurityConfig"
        },
        "snapshot": {
          "$ref": "#/$defs/SnapshotConfig"
        }
      },
      "required": [
        "port",
        "numShards",
        "allowCrossSlotStandalone",
        "scatterGatherTimeoutMs",
        "logging",
        "persistence",
        "snapshot",
        "metrics",
        "admin",
        "memory",
        "security"
      ]
    },
    "GrafanaConfig": {
      "type": "object",
      "properties": {
        "dashboard": {
          "$ref": "#/$defs/GrafanaDashboardConfig"
        }
      },
      "required": [
        "dashboard"
      ]
    },
    "GrafanaDashboardConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ]
    },
    "ImageConfig": {
      "type": "object",
      "properties": {
        "pullPolicy": {
          "type": "string"
        },
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        }
      },
      "required": [
        "repository",
        "tag",
        "pullPolicy"
      ]
    },
    "LoggingConfig": {
      "type": "object",
      "properties": {
        "format": {
          "type": "string"
        },
        "level": {
          "type": "string"
        }
      },
      "required": [
        "level",
        "format"
      ]
    },
    "MemoryConfig": {
      "type": "object",
      "properties": {
        "maxmemory": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "policy": {
          "type": "string"
        },
        "samples": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        }
      },
      "required": [
        "maxmemory",
        "policy",
        "samples"
      ]
    },
    "MetricsConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "otlp": {
          "$ref": "#/$defs/OtlpConfig"
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        }
      },
      "required": [
        "enabled",
        "port",
        "otlp"
      ]
    },
    "OtlpConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "endpoint": {
          "type": "string"
        },
        "intervalSecs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "enabled",
        "endpoint",
        "intervalSecs"
      ]
    },
    "PdbConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minAvailable": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "enabled",
        "minAvailable"
      ]
    },
    "PersistenceConfig": {
      "type": "object",
      "properties": {
        "blockCacheSizeMb": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        },
        "bloomFilterBits": {
          "type": "integer",
          "format": "int32"
        },
        "compactionRateLimitMb": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "compression": {
          "type": "string"
        },
        "dataDir": {
          "type": "string"
        },
        "durabilityMode": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "maxWriteBufferNumber": {
          "type": "integer",
          "format": "int32"
        },
        "syncIntervalMs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "writeBufferSizeMb": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        }
      },
      "required": [
        "enabled",
        "dataDir",
        "durabilityMode",
        "syncIntervalMs",
        "writeBufferSizeMb",
        "compression",
        "blockCacheSizeMb",
        "bloomFilterBits",
        "maxWriteBufferNumber",
        "compactionRateLimitMb"
      ]
    },
    "PersistenceVolumeConfig": {
      "type": "object",
      "properties": {
        "accessModes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "enabled": {
          "type": "boolean"
        },
        "size": {
          "type": "string"
        },
        "storageClass": {
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "storageClass",
        "size",
        "accessModes"
      ]
    },
    "ResourceConfig": {
      "type": "object",
      "properties": {
        "limits": {
          "$ref": "#/$defs/ResourceSpec"
        },
        "requests": {
          "$ref": "#/$defs/ResourceSpec"
        }
      },
      "required": [
        "limits",
        "requests"
      ]
    },
    "ResourceSpec": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      },
      "required": [
        "cpu",
        "memory"
      ]
    },
    "SecurityConfig": {
      "type": "object",
      "properties": {
        "requirepass": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ServiceConfig": {
      "type": "object",
      "properties": {
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "port",
        "annotations"
      ]
    },
    "ServiceMonitorConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string"
        },
        "scrapeTimeout": {
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "interval",
        "scrapeTimeout"
      ]
    },
    "SnapshotConfig": {
      "type": "object",
      "properties": {
        "dir": {
          "type": "string"
        },
        "intervalSecs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "maxSnapshots": {
          "type": "integer",
          "format": "uint",
          "minimum": 0
        }
      },
      "required": [
        "dir",
        "intervalSecs",
        "maxSnapshots"
      ]
    }
  }
}