# Generated by Cargo
# will have compiled files and executables
/debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Claude.ai
.claude/settings.local.json
.claude/worktrees/
.claude/todos/
CLAUDE.local.md

# Onyx Knowledge Base
onyx/.env
.mcp.json
*.zip

# bun
node_modules/

# Documentation site build output
website/dist/
website/.astro/


# Dev server state (per-worktree, written by dev_server.py)
.dev-server.json

# RocksDB data directories (created during testing/development)
frogdb-data/

# Redis compatibility test cache
.redis-tests/

# python
__pycache__/
*.pyc
*.pyo
.ruff_cache/
**/egg-info/
.pytest_cache/
.venv/

# cargo sweep cache
sweep.timestamp

# Load test reports (generated benchmark data)
testing/load/reports

# redis dump files
*.rdb

# jepsen test results
testing/jepsen/frogdb/store

# Code coverage profiling
*.profraw
*.profdata
coverage/

# Profiling output
causal-profile.json
flamegraph.svg
perf.data*

# OS-specific files
.DS_Store
Thumbs.db

# Editor swap/backup files
*.swp
*.swo
*~

# Proptest regression files
*.proptest-regressions

# mise local overrides
.mise.local.toml

# direnv (used for system RocksDB env vars)
.envrc

# Insta snapshot testing (pending snapshots)
*.snap.new

# Lefthook local overrides
lefthook-local.yml

# Playwright test output
playwright-report/
test-results/

# Self-hosted runner secrets
.github/runner/.env