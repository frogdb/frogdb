{
  "sandbox": {
    "filesystem": {
      "allowWrite": ["~/.blacksmith"]
    }
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/testbox-cleanup.sh",
            "timeout": 60,
            "statusMessage": "Stopping Blacksmith testboxes"
          }
        ]
      }
    ]
  }
}
