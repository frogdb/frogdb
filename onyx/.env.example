# ===========================================
# ONYX CONFIGURATION FOR FROGDB KNOWLEDGE BASE
# ===========================================
# Copy this file to .env and fill in your values

# ----- Web Domain -----
WEB_DOMAIN=http://localhost:3000

# ----- Authentication -----
# Disabled for local personal use
AUTH_TYPE=disabled

# ----- Database -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<generate-secure-password>

# ----- LLM Configuration -----
# Set your Anthropic API key here
# Get one at: https://console.anthropic.com/
GEN_AI_API_KEY=<your-anthropic-api-key>

# Using Claude via LiteLLM
# Models: claude-sonnet-4-20250514, claude-3-5-sonnet-20241022, etc.
GEN_AI_MODEL_VERSION=claude-sonnet-4-20250514

# ----- Feature Flags -----
# Show all connectors including File connector
SHOW_EXTRA_CONNECTORS=True

# ----- Index Settings -----
# Vespa language (English)
VESPA_LANGUAGE_OVERRIDE=en

# ----- Image Tag -----
IMAGE_TAG=latest
