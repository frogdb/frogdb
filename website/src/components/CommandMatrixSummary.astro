---
/**
 * Stat row for the command matrix: counts per support status.
 * Reads from auto-generated command-matrix.json.
 */

import data from '../data/command-matrix.json';

const { supported, partial, unsupported, extension } = (data as any).summary;
---

<div class="matrix-summary">
  <div class="stat-grid">
    <div class="stat-card">
      <span class="stat-value">{supported.toLocaleString()}</span>
      <span class="stat-label">Supported</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{partial.toLocaleString()}</span>
      <span class="stat-label">Partial</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{unsupported.toLocaleString()}</span>
      <span class="stat-label">Unsupported</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{extension.toLocaleString()}</span>
      <span class="stat-label">FrogDB Extensions</span>
      <span class="stat-note">subset of Supported</span>
    </div>
  </div>
</div>

<style>
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }
  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.25rem 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
  }
  .stat-value {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--sl-color-white);
  }
  .stat-label {
    font-size: 0.85rem;
    color: var(--sl-color-gray-2);
    margin-top: 0.25rem;
  }
  .stat-note {
    font-size: 0.72rem;
    color: var(--sl-color-gray-3);
    margin-top: 0.15rem;
    font-style: italic;
  }
</style>
