---
/**
 * Renders a config reference table for a given section from the
 * auto-generated config-reference.json.
 *
 * Usage in MDX:
 *   import ConfigTable from '../../components/ConfigTable.astro';
 *   <ConfigTable section="server" />
 */

interface Props {
  section: string;
}

const { section } = Astro.props;

import configData from '../data/config-reference.json';

const sectionInfo = (configData as any).sections[section];

if (!sectionInfo) {
  throw new Error(`ConfigTable: unknown section "${section}". Available: ${Object.keys((configData as any).sections).join(', ')}`);
}

function formatDefault(value: any): string {
  if (value === null || value === undefined) return '—';
  if (typeof value === 'string') return value === '' ? '`""`' : `\`"${value}"\``;
  if (typeof value === 'boolean') return `\`${value}\``;
  if (typeof value === 'number') return `\`${value}\``;
  return `\`${JSON.stringify(value)}\``;
}

function formatDescription(field: any): string {
  let desc = field.description || '';
  // Replace newlines with spaces for table cells
  desc = desc.replace(/\n/g, ' ');
  if (field.enum_values && field.enum_values.length > 0) {
    const values = field.enum_values.map((v: string) => `\`"${v}"\``).join(', ');
    desc += ` Options: ${values}.`;
  }
  return desc;
}

function formatType(field: any): string {
  return field.type;
}
---

<table>
  <thead>
    <tr>
      <th>Option</th>
      <th>Type</th>
      <th>Default</th>
      <th>Description</th>
    </tr>
  </thead>
  <tbody>
    {sectionInfo.fields.map((field: any) => (
      <tr>
        <td><code>{field.name}</code></td>
        <td>{formatType(field)}</td>
        <td set:html={formatDefault(field.default)} />
        <td set:html={formatDescription(field)} />
      </tr>
    ))}
  </tbody>
</table>
